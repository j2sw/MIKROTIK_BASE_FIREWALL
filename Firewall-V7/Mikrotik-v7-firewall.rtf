# Accept established, related, and untracked connections
/ip firewall filter add chain=input connection-state=established,related,untracked action=accept comment="Allow established/related/untracked"
/ip firewall filter add chain=forward connection-state=established,related,untracked action=accept comment="Forward established/related/untracked"
#
# Drop invalid packets
/ip firewall filter add chain=input connection-state=invalid action=drop comment="Drop invalid connections"
/ip firewall filter add chain=forward connection-state=invalid action=drop comment="Drop invalid forward connections"
